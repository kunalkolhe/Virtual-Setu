# ─────────────────────────────────────────────
#  Virtual Setu — Environment Variables Template
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ─────────────────────────────────────────────

# ── Supabase (Frontend + Server) ──────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_URL_BACKEND=https://your-project.supabase.co

# ── Supabase Service Role (Server-side only) ──
# Used by server/index.ts for admin operations (bypasses RLS)
SUPABASE_API_KEY=your-supabase-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Groq AI (Document Verification) ──────────
VITE_GROQ_API_KEY=your-groq-api-key

# ── Google Gemini AI (Chatbot) ────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── Razorpay (Payments) ───────────────────────
VITE_RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_ID=rzp_live_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ── ScraperAPI (Smart Checklist) ──────────────
VITE_SCRAPER_API_KEY=your-scraper-api-key

# ── YouTube API (Checklist Videos) ───────────
VITE_YOUTUBE_API_KEY=your-youtube-api-key

# ── Firebase (Auth / Realtime DB / Storage) ───
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-your-measurement-id

# ── Server Session (Express) ──────────────────
SESSION_SECRET=a-long-random-string-at-least-32-chars
